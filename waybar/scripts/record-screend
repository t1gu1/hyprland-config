#!/bin/bash

recordings=0

echo "<span font='26'>㬚窓</span>"

update() {
    if [ "$recordings" -gt 0 ]; then
        echo "<span font='26'>謹･</span> <span baseline_shift='5pt'>Recording</span>"
    else
        echo "<span font='26'>㬚窓</span>"
    fi
}

begin_record() {
    recordings=$((recordings + 1))
    update
}

end_record() {
    recordings=$((recordings - 1))
    update
}

exec sleep infinity &

pid="$!"
trap begin_record SIGUSR1
trap end_record SIGUSR2
trap "kill $pid" EXIT

while :; do
    wait "$pid"
done
